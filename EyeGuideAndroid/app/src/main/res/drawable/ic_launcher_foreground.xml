<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Iris circle with gradient -->
    <path
        android:pathData="M54,30 A24,24 0 1,1 54,78 A24,24 0 1,1 54,30 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="42"
                android:gradientRadius="28"
                android:type="radial">
                <item android:color="#FF0A84FF" android:offset="0.0" />
                <item android:color="#FF005ADC" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top eyelid arc -->
    <path
        android:pathData="M18,54 Q36,28 54,28 Q72,28 90,54"
        android:strokeWidth="2.5"
        android:strokeColor="#660A84FF"
        android:fillColor="#00000000" />

    <!-- Bottom eyelid arc -->
    <path
        android:pathData="M18,54 Q36,80 54,80 Q72,80 90,54"
        android:strokeWidth="2.5"
        android:strokeColor="#660A84FF"
        android:fillColor="#00000000" />

    <!-- Navigation arrow -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,46 L49.5,56 L54,52.5 L58.5,56 Z" />

    <!-- Compass dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,58 A1.5,1.5 0 1,1 54,61 A1.5,1.5 0 1,1 54,58 Z" />
</vector>

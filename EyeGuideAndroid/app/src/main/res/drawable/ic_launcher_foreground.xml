<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- AI scan ring - lime green accent -->
    <path
        android:pathData="M30,54 A24,24 0 1,1 78,54 A24,24 0 1,1 30,54 Z"
        android:strokeWidth="2"
        android:strokeColor="#FFD0F553"
        android:fillColor="#00000000" />

    <!-- Iris/lens circle - dark with subtle radial gradient -->
    <path
        android:pathData="M32,54 A22,22 0 1,1 76,54 A22,22 0 1,1 32,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="49"
                android:gradientRadius="26"
                android:type="radial">
                <item android:color="#FF2C2C2E" android:offset="0.0" />
                <item android:color="#FF1A1A1A" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Main highlight reflection - white -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M56,46 A5,5 0 1,1 66,46 A5,5 0 1,1 56,46 Z" />

    <!-- AI indicator dot - lime green -->
    <path
        android:fillColor="#FFD0F553"
        android:pathData="M45.5,62 A2.5,2.5 0 1,1 50.5,62 A2.5,2.5 0 1,1 45.5,62 Z" />
</vector>
